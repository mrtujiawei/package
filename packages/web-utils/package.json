{
  "name": "@mrtujiawei/web-utils",
  "version": "1.1.4",
  "description": "web相关工具函数，只能在网页上使用的工具函数",
  "main": "dist/webUtils.js",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "start": "echo 'web-utils started'",
    "build": "webpack",
    "clean": "rm dist -rf",

    "prepush": "git add . && git commit -m 'feat(all):auto commit'",
    "push": "git push",

    "prepub": "npm run clean && npm run build",
