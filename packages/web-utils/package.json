  "bugs": {
    "url": "https://github.com/mrtujiawei/package/issues"
  },
  "homepage": "https://github.com/mrtujiawei/package#readme",
  "devDependencies": {
    "@babel/core": "^7.14.0",
    "@babel/plugin-transform-runtime": "^7.16.0",
    "@babel/preset-env": "^7.14.1",
    "babel-loader": "^8.2.2",
    "webpack": "^5.36.2",
    "webpack-cli": "^4.7.0"
  },
  "dependencies": {
    "@mrtujiawei/utils": "^1.8.8"
  }
