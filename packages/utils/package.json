{
  "name": "@mrtujiawei/utils",
  "version": "1.9.4",
  "description": "把自己写的工具函数打包发布到npm上",
  "types": "types/index.d.ts",
  "main": "dist/utils.js",
  "files": [
    "dist",
    "types"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "start": "tsc -w",
    "build": "tsc && webpack",

    "doc": "doctoc README.md",
    "push": "git add . && git commit -m 'feat(all): 自动提交' && git push",
    "clean": "rm dist types -rf",

    "test": "jest",
    "test:coverage": "jest --coverage",

    "prepub": "npm run clean && npm run doc && npm run build",
    "pub": "npm publish",
    "postpub": "npm run push"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrtujiawei/package.git"
  },
  "keywords": [
    "util",
    "tool"
  ],
  "author": "屠佳伟",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mrtujiawei/package/issues"
  },
  "homepage": "https://github.com/mrtujiawei/package#readme",
  "devDependencies": {
    "@babel/core": "^7.14.0",
    "@babel/plugin-transform-runtime": "^7.16.0",
    "@babel/preset-env": "^7.14.1",
    "@babel/preset-typescript": "^7.16.0",
    "@types/jest": "^26.0.23",
    "babel-loader": "^8.2.2",
    "clean-webpack-plugin": "^4.0.0",
    "core-js": "^3.19.1",
    "doctoc": "^2.1.0",
    "jest": "^26.6.3",
    "ts-jest": "^26.5.6",
    "typescript": "^4.2.4",
    "webpack": "^5.36.2",
    "webpack-cli": "^4.7.0"
  },
  "jest": {
    "testEnvironment": "node"
  }
}
